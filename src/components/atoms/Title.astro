---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!-- TITLE -->
<h1>{title}</h1>

<style>
  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: var(--background-base--dark);
  }

  :global(body.dark) h1 {
    color: var(--text-color-base--dark-alt);
  }
</style>
