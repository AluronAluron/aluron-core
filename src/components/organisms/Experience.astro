---
import { EXPERIENCES } from "../../common/data/portfolio/experience.data";
import { DEFAULT_LOCALE_PACK } from "../../i18n";

const ui = DEFAULT_LOCALE_PACK.data;
const locale = DEFAULT_LOCALE_PACK.locale;

const CURRENT_EXPERIENCES = EXPERIENCES.filter((exp) => exp.current && exp.level === 0);
const PAST_EXPERIENCES = EXPERIENCES.filter((exp) => !exp.current && !exp.wasIntern && exp.level === 0);
const INTERN_EXPERIENCES = EXPERIENCES.filter((exp) => exp.wasIntern && exp.level === 0);
---

<section id="experience">
  <h2 data-i18n="experience-title">{ui?.sections.experience.title}</h2>

  {CURRENT_EXPERIENCES.length > 0 && (
    <div style="margin-bottom: 3rem;">
      {CURRENT_EXPERIENCES.map((exp) => (
        <div class="current-experience">
          <span data-i18n="experience-currently">{ui?.sections.experience.currently}</span>
          <h3 data-exp-title={exp.id}>{exp.title[locale] ?? exp.title["es-ES"]}</h3>
          <div class="exp-company">
            <button class="tech-btn-icon" data-exp-id={exp.id}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
              <span class="tech-tooltip" data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</span>
            </button>
            <p class="company-name">{exp.company}</p>
          </div>
          <p class="exp-period" data-exp-period={exp.id}>{exp.period[locale] ?? exp.period["es-ES"]}</p>
          <p class="exp-desc" data-exp-desc={exp.id}>{exp.description[locale] ?? exp.description["es-ES"]}</p>
          <div class="tech-popup" id={`popup-${exp.id}`}>
            <div class="tech-popup-content">
              <h4 data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</h4>
              <div class="tech-list">
                {exp.technologies.map((tech) => (<span class="tech-tag">{tech}</span>))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  <!-- TABS -->
  <div class="exp-tabs">
    <button class="exp-tab active" data-tab="professional" data-i18n="experience-past">{ui?.sections.experience.past}</button>
    <button class="exp-tab" data-tab="internships" data-i18n="experience-internships">{ui?.sections.experience.internships}</button>
  </div>

  <!-- PROFESSIONAL TAB -->
  <div class="exp-tab-content active" id="tab-professional">
    {PAST_EXPERIENCES.map((exp) => (
      <div class="timeline-item">
        <h3 data-exp-title={exp.id}>{exp.title[locale] ?? exp.title["es-ES"]}</h3>
        <div class="exp-company">
          <button class="tech-btn-icon" data-exp-id={exp.id}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            <span class="tech-tooltip" data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</span>
          </button>
          <p class="company-name">{exp.company}</p>
        </div>
        <p class="exp-period" data-exp-period={exp.id}>{exp.period[locale] ?? exp.period["es-ES"]}</p>
        <p class="exp-desc" data-exp-desc={exp.id}>{exp.description[locale] ?? exp.description["es-ES"]}</p>
        <div class="tech-popup" id={`popup-${exp.id}`}>
          <div class="tech-popup-content">
            <h4 data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</h4>
            <div class="tech-list">
              {exp.technologies.map((tech) => (<span class="tech-tag">{tech}</span>))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- INTERNSHIPS TAB -->
  <div class="exp-tab-content" id="tab-internships">
    {INTERN_EXPERIENCES.map((exp) => (
      <div class="timeline-item">
        <h3 data-exp-title={exp.id}>{exp.title[locale] ?? exp.title["es-ES"]}</h3>
        <div class="exp-company">
          <button class="tech-btn-icon" data-exp-id={exp.id}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            <span class="tech-tooltip" data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</span>
          </button>
          <p class="company-name">{exp.company}</p>
        </div>
        <p class="exp-period" data-exp-period={exp.id}>{exp.period[locale] ?? exp.period["es-ES"]}</p>
        <p class="exp-desc" data-exp-desc={exp.id}>{exp.description[locale] ?? exp.description["es-ES"]}</p>
        <div class="tech-popup" id={`popup-${exp.id}`}>
          <div class="tech-popup-content">
            <h4 data-i18n="experience-techLabel">{ui?.sections.experience.techLabel}</h4>
            <div class="tech-list">
              {exp.technologies.map((tech) => (<span class="tech-tag">{tech}</span>))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import { currentLocale } from "../../store/locale-store";
  import { EXPERIENCES } from "../../common/data/portfolio/experience.data";

  // Locale reactivity
  currentLocale.subscribe((bundle) => {
    if (!bundle || !bundle.data) return;
    const locale = bundle.locale;
    const { experience } = bundle.data.sections;

    document.querySelectorAll<HTMLElement>('[data-i18n="experience-title"]').forEach((el) => (el.textContent = experience.title));
    document.querySelectorAll<HTMLElement>('[data-i18n="experience-currently"]').forEach((el) => (el.textContent = experience.currently));
    document.querySelectorAll<HTMLElement>('[data-i18n="experience-past"]').forEach((el) => (el.textContent = experience.past));
    document.querySelectorAll<HTMLElement>('[data-i18n="experience-internships"]').forEach((el) => (el.textContent = experience.internships));
    document.querySelectorAll<HTMLElement>('[data-i18n="experience-techLabel"]').forEach((el) => (el.textContent = experience.techLabel));

    EXPERIENCES.forEach((exp) => {
      document.querySelectorAll<HTMLElement>(`[data-exp-title="${exp.id}"]`).forEach((el) => (el.textContent = exp.title[locale] ?? ""));
      document.querySelectorAll<HTMLElement>(`[data-exp-period="${exp.id}"]`).forEach((el) => (el.textContent = exp.period[locale] ?? ""));
      document.querySelectorAll<HTMLElement>(`[data-exp-desc="${exp.id}"]`).forEach((el) => (el.textContent = exp.description[locale] ?? ""));
    });
  });

  // Tabs
  document.querySelectorAll<HTMLButtonElement>(".exp-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document.querySelectorAll(".exp-tab").forEach((t) => t.classList.remove("active"));
      document.querySelectorAll(".exp-tab-content").forEach((c) => c.classList.remove("active"));
      tab.classList.add("active");
      document.getElementById(`tab-${tab.dataset.tab}`)?.classList.add("active");
    });
  });

  // Tech popup toggle
  document.querySelectorAll(".tech-btn-icon").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      const target = e.currentTarget as HTMLElement;
      const expId = target.dataset.expId;
      const popup = document.getElementById(`popup-${expId}`);
      document.querySelectorAll(".tech-popup.active").forEach((p) => {
        if (p !== popup) p.classList.remove("active");
      });
      popup?.classList.toggle("active");
    });
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest(".tech-btn-icon") && !target.closest(".tech-popup")) {
      document.querySelectorAll(".tech-popup.active").forEach((popup) => {
        popup.classList.remove("active");
      });
    }
  });
</script>

<style>
  .exp-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 2rem;
    border-bottom: 2px solid #e2e8f0;
  }

  .exp-tab {
    padding: 10px 20px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    color: #718096;
    transition: all 0.2s ease;
  }

  .exp-tab:hover {
    color: #88ccca;
  }

  .exp-tab.active {
    color: #88ccca;
    border-bottom-color: #88ccca;
    font-weight: 600;
  }

  :global(body.dark) .exp-tabs {
    border-bottom-color: #4a5568;
  }

  .exp-tab-content {
    display: none;
  }

  .exp-tab-content.active {
    display: block;
    animation: fadeTab 0.3s ease;
  }

  @keyframes fadeTab {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .exp-company {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    transition: gap 0.3s ease;
  }

  .timeline-item .exp-company {
    justify-content: flex-start;
  }

  .current-experience .exp-company,
  .timeline-item:hover .exp-company {
    gap: 10px;
  }

  .company-name {
    color: #88ccca;
    font-weight: 600;
    margin: 0.5rem 0;
  }

  .current-experience {
    text-align: center;
    padding: 20px;
    margin-bottom: 20px;
    position: relative;
  }

  .current-experience h3 {
    font-size: 1.75rem;
    font-weight: 700;
  }

  .exp-period {
    font-size: 0.9rem;
    color: #718096;
    margin-bottom: 0.75rem;
  }

  .exp-desc {
    line-height: 1.8;
  }

  .current-experience .exp-desc {
    max-width: 700px;
    margin: 0 auto 1rem;
  }

  .tech-btn-icon {
    background: #f7a399;
    color: #fff;
    border: none;
    width: 0;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  .current-experience .tech-btn-icon,
  .timeline-item:hover .tech-btn-icon {
    opacity: 1;
    width: 28px;
  }

  .tech-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-5px);
    background: #2d3748;
    color: #fff;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    margin-bottom: 5px;
  }

  :global(body.dark) .tech-tooltip {
    background: #f7fafc;
    color: #2d3748;
  }

  .tech-btn-icon:hover .tech-tooltip {
    opacity: 1;
  }

  .tech-btn-icon:hover {
    background: #e57a6d;
    transform: scale(1.1);
    box-shadow: 0 4px 8px rgba(247, 163, 153, 0.3);
  }

  .tech-popup {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 10px;
    z-index: 100;
  }

  .tech-popup.active {
    display: block;
    animation: popupSlide 0.3s ease;
  }

  @keyframes popupSlide {
    from { opacity: 0; transform: translateY(-10px) scale(0.95); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  .tech-popup-content {
    background: #fff;
    padding: 20px;
    border-radius: 12px;
    position: relative;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    border: 2px solid #f7a399;
  }

  .tech-popup-content h4 {
    margin-bottom: 1rem;
    color: #2d3748;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  :global(body.dark) .tech-popup-content {
    background: #2d3748;
  }

  :global(body.dark) .tech-popup-content h4 {
    color: #e2e8f0;
  }

  .tech-tag {
    background: #f7a399;
    color: #c44569;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
