---
import { DEFAULT_LOCALE_PACK } from "../../i18n";

const ui = DEFAULT_LOCALE_PACK.data;
---

<section id="about">
  <h2 data-i18n="about-title">About me</h2>
  <p id="about-text" class="about-text">{ui?.personalInfo.about ?? ""}</p>
</section>

<script>
  import { currentLocale } from "../../store/locale-store";

  const titleEl = document.querySelector('[data-i18n="about-title"]') as HTMLElement;
  const textEl = document.getElementById("about-text") as HTMLElement;

  currentLocale.subscribe((bundle) => {
    if (!bundle || !bundle.data) return;
    titleEl.textContent = bundle.locale === "es-ES" ? "Sobre mí" : "About me";
    textEl.textContent = bundle.data.personalInfo.about;
  });
</script>

<style>
  .about-text {
    font-size: 1.05rem;
    line-height: 2;
    max-width: 650px;
    color: #4a5568;
  }

  :global(body.dark) .about-text {
    color: #cbd5e0;
  }
</style>
